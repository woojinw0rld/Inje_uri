#!/bin/sh

violations=0

for f in $(git diff --cached --name-only --diff-filter=ACM); do
  [ -f "$f" ] || continue

  case "$f" in
    node_modules/*|.next/*|.git/*) continue ;;
  esac

  file_info=$(file "$f" 2>/dev/null || true)

  if echo "$file_info" | grep -Eiq 'ELF|PE32|Mach-O|executable'; then
    echo "❌ Executable binary blocked: $f"
    echo "   $file_info"
    violations=1
  fi

  case "$f" in
    let|let\;*|*\;chmod*|*\;curl*|*\;wget*)
      echo "❌ Suspicious filename blocked: $f"
      violations=1
      ;;
  esac
done

if [ "$violations" -ne 0 ]; then
  echo "Commit blocked by security hook."
  exit 1
fi
